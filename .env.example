# --- Vercel Blob (document store) ---
# Create a Blob store in the Vercel dashboard; this is the read-write token.
# Full read/write to the whole store — keep it server-side only.
BLOB_READ_WRITE_TOKEN=vercel_blob_rw_xxxxxxxx
# Set to 'private' if your Blob store uses private access; otherwise 'public'.
BLOB_ACCESS=public

# --- Runpod serverless vLLM endpoint (the GPU backend) ---
RUNPOD_API_KEY=rpa_xxxxxxxx
RUNPOD_ENDPOINT_ID=xxxxxxxx

# Model id served by the endpoint (must match MODEL_NAME on the worker).
RUNPOD_MODEL=Qwen/Qwen3.5-9B

# Optional: restrict which Blob path prefixes the app may read/write.
# Comma-separated. Empty = allow all paths.
DOC_PATH_ALLOWLIST=
