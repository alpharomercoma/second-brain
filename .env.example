# Local-first: documents live in the browser (IndexedDB) and each user enters
# their own Mistral API key in the app — so NO server secrets are required in
# production. Deploy with an EMPTY env and you're safe.

# --- Optional server fallback key (NOT for production) ---
# A request normally carries the user's own key. To let the server fall back to a
# shared key (e.g. local testing or a private demo), set BOTH of these. Without
# the flag, the env key is ignored — this prevents the deployment from becoming an
# open proxy that bills your key.
# MISTRAL_ALLOW_SERVER_KEY=1
# MISTRAL_API_KEY=xxxxxxxx

# Optional: override the default model id (mistral-large-latest).
# MISTRAL_MODEL=mistral-large-latest
